{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(supabase *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(docker-compose up*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(docker-compose down --volumes*)"
    ]
  },
  "hooks": {
    "SubagentStop": [
      {
        "matcher": "db-agent",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/after-db-agent.sh"
          }
        ]
      }
    ]
  }
}
